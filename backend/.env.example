# ========== 数据库 ==========
# PostgreSQL 连接串 (需启用 pgvector 扩展)
# 本地开发用 localhost，Docker 部署时由 docker-compose.yml 覆盖为容器内地址
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/liuguang

# ========== 飞书开放平台 ==========
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 飞书 Webhook 机器人地址 (用于 ETL 异常告警，可选)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# 飞书租户域名 (用于构建多维表格链接，如 abc123.feishu.cn)
FEISHU_BASE_DOMAIN=xxx.feishu.cn

# ========== 系统超管 ==========
# 不可被降级的系统管理员飞书 open_id
SUPER_ADMIN_OPEN_ID=ou_xxxxxxxxxxxxxxxx

# ========== ETL 注册中心 ==========
# 飞书多维表格: ETL 抓取注册中心的 app_token 和 table_id (可选，没有 ETL 源可留空)
ETL_REGISTRY_APP_TOKEN=bascnXXXXXXXXXXXX
ETL_REGISTRY_TABLE_ID=tblXXXXXXXXXXXX

# ETL 定时任务 cron (分钟间隔, 默认 30)
ETL_CRON_MINUTES=30

# ========== JWT 鉴权 ==========
# 生产环境务必修改为随机长字符串！
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ========== 大模型 (Schema 映射 / 关键信息提取) ==========
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ========== Embedding 模型 ==========
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxx
EMBEDDING_BASE_URL=https://api.deepseek.com/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# ========== 视觉模型 (图片内容提取，可选) ==========
VISION_LLM_MODEL=qwen3-vl-8b-instruct

# ========== 流光助手 Agent LLM (可与上面相同也可独立配置) ==========
AGENT_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
AGENT_LLM_BASE_URL=https://api.deepseek.com/v1
AGENT_LLM_MODEL=deepseek-chat

# ========== ASR 语音转文字 (音频上传功能，可选) ==========
ASR_API_KEY=sk-xxxxxxxxxxxxxxxx
ASR_BASE_URL=https://api.deepseek.com/v1
ASR_MODEL=funasr

# ========== 文件上传 ==========
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,txt,csv,xlsx,png,jpg,jpeg,mp3,wav,m4a,aac,ogg,flac
