# ========== 流光智能数据平台 — 生产环境配置模板 ==========
# 复制本文件为 .env 并填入真实值
# ⚠️  切勿将 .env 提交到版本控制

# ========== 数据库 ==========
# Docker Compose 内部网络使用服务名 postgres
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_STRONG_PASSWORD@postgres:5432/liuguang

# ========== 飞书开放平台 ==========
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# ========== ETL 注册中心 ==========
ETL_REGISTRY_APP_TOKEN=bascnXXXXXXXXXXXX
ETL_REGISTRY_TABLE_ID=tblXXXXXXXXXXXX
ETL_CRON_MINUTES=30

# ========== JWT 鉴权 ==========
# ⚠️  生产环境务必使用强随机密钥 (openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ========== 大模型 (Schema 映射) ==========
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ========== Embedding 模型 ==========
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxx
EMBEDDING_BASE_URL=https://api.deepseek.com/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1536

# ========== 流光助手 Agent LLM ==========
AGENT_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
AGENT_LLM_BASE_URL=https://api.deepseek.com/v1
AGENT_LLM_MODEL=deepseek-chat
