# =============================================
# 流光数据平台 - Docker Compose 环境变量
# 复制为 .env 后填入实际值
# =============================================

# ---- 数据库密码 (postgres 服务使用) ----
POSTGRES_PASSWORD=postgres

# ---- 前端构建参数 (Vite 构建时注入) ----
# 飞书应用 App ID
VITE_FEISHU_APP_ID=cli_xxxxxxxxxx
# OAuth 回调地址: http://<你的服务器IP>/login
VITE_FEISHU_REDIRECT_URI=http://YOUR_SERVER_IP/login
